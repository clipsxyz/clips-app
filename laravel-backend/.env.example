# Query profiler (dev/testing by default)
# Set to true to force-enable outside local/testing.
QUERY_PROFILER_ENABLED=false

# Warning log thresholds (only used by QueryProfiler middleware)
QUERY_PROFILER_LOG_QUERY_COUNT_THRESHOLD=25
QUERY_PROFILER_LOG_SLOWEST_MS_THRESHOLD=50
QUERY_PROFILER_LOG_TOTAL_MS_THRESHOLD=120
QUERY_PROFILER_LOG_REQUEST_MS_THRESHOLD=500

# Google Places / Maps API key (optional). Used by /api/search/places.
GOOGLE_MAPS_API_KEY=

# Twilio OTP delivery (optional). Used by /api/auth/phone/send-code.
# OTP_CHANNEL supports: whatsapp, sms
# For WhatsApp set TWILIO_WHATSAPP_FROM like: whatsapp:+14155238886
# For SMS set TWILIO_FROM like: +1234567890
OTP_CHANNEL=whatsapp
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_WHATSAPP_FROM=

# Facebook social graph integration (Find Facebook Friends)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_VERSION=v20.0

# Frontend app URL used by invite social card redirects
FRONTEND_APP_URL=http://localhost:5173

