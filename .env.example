# Copy this file to `.env` and fill in real values. Do not commit `.env`.
# Vite only exposes variables prefixed with VITE_ to the client bundle.

# --- API ---
# Laravel API base URL (include /api if your backend mounts there)
VITE_API_URL=http://localhost:8000/api
# Set to false to use mock/local data instead of Laravel (see project docs)
VITE_USE_LARAVEL_API=true

# --- Maps ---
VITE_GOOGLE_MAPS_API_KEY=

# --- App ---
VITE_APP_NAME=Gazetteer
VITE_APP_VERSION=1.0.0

# --- Feature flags ---
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_PWA=true

# --- Development ---
# When true, some flows skip backend (e.g. gallery preview)
VITE_DEV_MODE=false

# --- Realtime (optional) ---
# WebSocket URL for Socket.IO, if used
VITE_SOCKETIO_URL=

# --- Payments (optional) ---
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Error monitoring (optional) ---
VITE_SENTRY_DSN=
VITE_RELEASE_VERSION=

# --- Firebase / FCM (optional; leave blank if not using) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=
